{
  "name": "hl-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "node --require ./scripts/nuxt-vite-node-socket-guard.cjs ./node_modules/nuxt/bin/nuxt.mjs dev --host 127.0.0.1",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test": "vitest run",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "nuxi typecheck"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.3",
    "@nuxtjs/supabase": "^2.0.9",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@supabase/supabase-js": "^2.108.0",
    "dotenv": "^17.4.2",
    "html2pdf.js": "^0.14.0",
    "nuxt": "^4.4.7",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "husky": "^8.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "shadcn-nuxt": "^2.7.4",
    "vitest": "^4.1.8"
  }
}
